# Supabase Postgres connection string (Project Settings -> Database -> Connection string -> URI)
# Use the "Transaction" pooler connection (port 6543) for DATABASE_URL and the
# "Session" pooler / direct connection (port 5432) for DIRECT_URL (Prisma migrations need a direct, non-pooled connection).
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:5432/postgres"

PORT=4000
CORS_ORIGIN="*"
